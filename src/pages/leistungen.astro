---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const services = [
  {
    id: 'zufahrtssteuerung',
    title: 'Zufahrts- und Liefersteuerung',
    description: 'Organisation und Koordination von Zufahrten und Lieferungen für einen strukturierten Baustellenverkehr.',
    image: '/images/leistung1.webp',
    features: [
      'Koordination aller Baustellenzufahrten',
      'Terminplanung für Lieferungen',
      'Management von Kurzzeitparkzonen',
      'Verhinderung von Staus und Wartezeiten',
    ],
    icon: 'M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0',
  },
  {
    id: 'materialfluss',
    title: 'Material- und Personalflusskoordination',
    description: 'Koordination von Materiallieferungen und Personaleinsätzen für strukturierte Abläufe auf der Baustelle.',
    image: '/images/leistung2.webp',
    features: [
      'Just-in-Time Materialbereitstellung',
      'Koordination von Lagerflächen',
      'Personaldisposition und -einsatzplanung',
      'Optimierung von Transportwegen',
    ],
    icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10',
  },
  {
    id: 'baustellenorganisation',
    title: 'Baustellenorganisation und Ablaufsteuerung',
    description: 'Organisation und Strukturierung der Baustellenabläufe – von der Planung bis zur Übergabe.',
    image: '/images/leistung3.webp',
    features: [
      'Gesamtkoordination der Baustellenaktivitäten',
      'Erstellung und Überwachung von Zeitplänen',
      'Koordination von Infrastruktur',
      'Regelmäßige Status-Meetings',
    ],
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  },
  {
    id: 'lieferkoordination',
    title: 'Koordination von Lieferungen und Gewerken',
    description: 'Synchronisation aller Gewerke und Lieferanten für termingerechte Abläufe.',
    image: '/images/leistung4.webp',
    features: [
      'Abstimmung aller Gewerke untereinander',
      'Management von Lieferterminen',
      'Priorisierung kritischer Lieferungen',
      'Störungsmanagement und Lösungsfindung',
    ],
    icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  },
  {
    id: 'bauleitungsunterstuetzung',
    title: 'Unterstützung der Bauleitung vor Ort',
    description: 'Unterstützung der Bauleitung bei der Organisation und Koordination der Baustellenabläufe.',
    image: '/images/leistung5.webp',
    features: [
      'Vertretung der Bauleitung vor Ort',
      'Übernahme operativer Tagesgeschäfte',
      'Direkte Ansprechperson für Gewerke',
      'Entlastung bei Routineaufgaben',
    ],
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    id: 'dokumentation',
    title: 'Tagesberichte, Protokolle und Übergaben',
    description: 'Lückenlose Dokumentation ist die Grundlage für rechtssichere Projektabwicklung.',
    image: '/images/leistung6.webp',
    features: [
      'Tägliche Baustellenberichte',
      'Protokollierung von Besprechungen',
      'Übergabeprotokolle und Abnahmen',
      'Digitale Archivierung',
    ],
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
  {
    id: 'baustellensicherheit',
    title: 'Integrierte Baustellensicherheit',
    description: 'Sicherheitsleistungen erfolgen in Zusammenarbeit mit METRA Sicherheitsdienste.',
    image: '/images/leistung7.webp',
    features: [
      'Baustellenüberwachung und Zugangskontrollen',
      'Objektschutz während Bauphasen',
      'Brandwachen und sicherheitsrelevante Präsenz',
      'Koordination interner Sicherheitsdienste',
    ],
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    id: 'unterstuetzende-services',
    title: 'Unterstützende Services',
    description: 'Ergänzende Leistungen zur Unterstützung der Baustellenorganisation.',
    image: '/images/leistung8.webp',
    features: [
      'Schlüssel- und Zugangsmanagement',
      'Koordination von Hebe- und Fördertechnik',
      'Unterstützung bei temporären Sicherheitskonzepten',
      'Präsenz vor Ort als verlängerter Arm der Bauleitung',
    ],
    icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
  },
];

const benefits = [
  {
    title: 'Ein Ansprechpartner',
    description: 'Für die komplette Baulogistik – keine Kommunikationsbrüche.',
    icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
  },
  {
    title: 'Klare Verantwortlichkeiten',
    description: 'Transparente Zuständigkeiten und lückenlose Dokumentation.',
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
  {
    title: '24/7 Verfügbarkeit',
    description: 'Rund um die Uhr für Sie da – auch an Wochenenden und Feiertagen.',
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Praxisorientierte Lösungen',
    description: 'Unsere Konzepte orientieren sich an realen Baustellenabläufen.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    title: 'Logistik und Baustellensicherheit aus einer Hand',
    description: 'Durch die Zusammenarbeit mit METRA Sicherheitsdienste optimal abgestimmt.',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    title: 'Flexible Einsatzplanung',
    description: 'Anpassung an Baufortschritt, Projektgröße und individuelle Anforderungen.',
    icon: 'M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4',
  },
];

const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Startseite',
      item: 'https://www.metra-baulogistik.de',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Leistungen',
      item: 'https://www.metra-baulogistik.de/leistungen',
    },
  ],
};

const schemaService = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Baulogistik und Projektsteuerung',
  provider: {
    '@type': 'Organization',
    name: 'METRA Baulogistik & Projektsteuerung GmbH',
  },
  areaServed: {
    '@type': 'City',
    name: 'Köln',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Baulogistik Leistungen',
    itemListElement: services.map((service, index) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: service.title,
        description: service.description,
      },
    })),
  },
};
---

<Layout 
  title="Leistungen | METRA Baulogistik & Projektsteuerung GmbH"
  description="Unsere umfassenden Baulogistik-Leistungen: Zufahrtssteuerung, Materialfluss, Baustellenorganisation, Lieferkoordination, Bauleitungsunterstützung und Dokumentation."
  canonical="/leistungen"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaService)} />
  
  <Header />
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="relative py-20 md:py-32 overflow-hidden" aria-labelledby="services-hero-title">
      <div class="absolute inset-0 opacity-5" aria-hidden="true">
        <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
      </div>
      
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <nav aria-label="Breadcrumb">
            <ol class="flex items-center gap-2 text-sm text-secondary mb-6">
              <li><a href="/" class="hover:text-accent transition-colors">Startseite</a></li>
              <li aria-hidden="true">/</li>
              <li aria-current="page" class="text-accent">Leistungen</li>
            </ol>
          </nav>
          
          <p class="text-accent font-semibold tracking-wider text-sm mb-4">UNSERE LEISTUNGEN</p>
          <h1 id="services-hero-title" class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
            Komplette Baulogistik aus einer Hand
          </h1>
          <p class="text-lg md:text-xl text-secondary leading-relaxed max-w-2xl">
            Von der ersten Planung bis zur finalen Dokumentation – wir begleiten Ihr Bauprojekt in allen Phasen mit professioneller Logistik und Projektsteuerung.
          </p>
        </div>
      </div>
    </section>

    <!-- Services Detail Section WITH IMAGES -->
    <section class="py-20 md:py-32 bg-black/20" aria-labelledby="services-detail-title">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="services-detail-title" class="sr-only">Detaillierte Leistungsübersicht</h2>
        
        <div class="space-y-20 md:space-y-32">
          {services.map((service, index) => (
            <article 
              id={service.id}
              class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center"
            >
              {/* Image - alternates left/right */}
              <div class={`relative ${index % 2 === 1 ? 'lg:order-2' : ''}`}>
                <div class="relative rounded-2xl overflow-hidden aspect-[16/9]">
                  <img 
                    src={service.image} 
                    alt={service.title}
                    class="w-full h-full object-cover"
                    loading="lazy"
                    width="600"
                    height="450"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-background/80 via-transparent to-transparent"></div>
                  
                  {/* Service Icon */}
                  <div class="absolute top-4 left-4 w-14 h-14 bg-accent text-background rounded-full flex items-center justify-center shadow-lg text-2xl">
                    {index === 0 && '🚚'}
                    {index === 1 && '📦'}
                    {index === 2 && '🏗'}
                    {index === 3 && '🤝'}
                    {index === 4 && '👷'}
                    {index === 5 && '📋'}
                    {index === 6 && '🛡'}
                    {index === 7 && '🔧'}
                  </div>
                </div>
                
                {/* Decorative element */}
                <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-accent/10 rounded-full blur-2xl" aria-hidden="true"></div>
              </div>
              
              {/* Content */}
              <div class={index % 2 === 1 ? 'lg:order-1' : ''}>
                <div class="inline-flex items-center gap-2 px-3 py-1 bg-accent/10 rounded-full text-accent text-sm font-medium mb-4">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon}/>
                  </svg>
                  Leistungsbereich
                </div>
                <h3 class="text-2xl md:text-3xl font-bold text-white mb-4">
                  {service.title}
                </h3>
                <p class="text-secondary text-lg leading-relaxed mb-6">
                  {service.description}
                </p>
                
                <h4 class="text-white font-semibold mb-3">Das leisten wir für Sie:</h4>
                <ul class="space-y-2">
                  {service.features.map((feature) => (
                    <li class="flex items-start gap-3">
                      <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                      </svg>
                      <span class="text-secondary">{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Benefits Section -->
    <section class="py-20 md:py-32" aria-labelledby="benefits-title">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <p class="text-accent font-semibold tracking-wider text-sm mb-3">IHR VORTEIL</p>
          <h2 id="benefits-title" class="text-3xl md:text-4xl font-bold text-white mb-4">
            Warum METRA?
          </h2>
          <p class="text-secondary text-lg">
            Überzeugende Argumente für eine Zusammenarbeit mit uns.
          </p>
        </div>
        
        <div class="grid md:grid-cols-3 gap-8">
          {benefits.map((benefit) => (
            <div class="text-center">
              <div class="w-16 h-16 bg-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={benefit.icon}/>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white mb-2">{benefit.title}</h3>
              <p class="text-secondary">{benefit.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Process Teaser -->
    <section class="py-20 md:py-32 bg-black/20" aria-labelledby="process-teaser-title">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-accent font-semibold tracking-wider text-sm mb-3">UNSER VORGEHEN</p>
            <h2 id="process-teaser-title" class="text-3xl md:text-4xl font-bold text-white mb-4">
              Strukturiert zum Projekterfolg
            </h2>
            <p class="text-secondary text-lg mb-6">
              Unser bewährter 4-Schritte-Ansatz garantiert eine professionelle Abwicklung Ihres Bauprojekts – von der ersten Analyse bis zur finalen Dokumentation.
            </p>
            <a 
              href="/#process-title"
              class="inline-flex items-center text-accent font-semibold hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded"
            >
              4-Schritte-Ansatz ansehen
              <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
          
          <div class="grid grid-cols-2 gap-4">
            {[
              { num: '01', title: 'Analyse', desc: 'Vor-Ort-Bedarfsanalyse' },
              { num: '02', title: 'Konzept', desc: 'Maßgeschneidertes Konzept' },
              { num: '03', title: 'Einsatz', desc: 'Qualifiziertes Team vor Ort' },
              { num: '04', title: 'Reporting', desc: 'Lückenlose Dokumentation' },
            ].map((step) => (
              <div class="bg-background border border-white/5 rounded-xl p-6 text-center">
                <span class="text-3xl font-bold text-accent">{step.num}</span>
                <h3 class="text-white font-semibold mt-2 mb-1">{step.title}</h3>
                <p class="text-secondary text-sm">{step.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 md:py-32" aria-labelledby="services-cta-title">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="relative bg-accent rounded-2xl p-8 md:p-16 overflow-hidden">
          <div class="absolute inset-0 opacity-10" aria-hidden="true">
            <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, #17181d 1px, transparent 0); background-size: 24px 24px;"></div>
          </div>
          
          <div class="relative text-center">
            <h2 id="services-cta-title" class="text-3xl md:text-4xl lg:text-5xl font-bold text-background mb-4">
              Projekt gemeinsam planen?
            </h2>
            <p class="text-background/80 text-lg md:text-xl mb-8 max-w-2xl mx-auto">
              Lassen Sie uns über Ihr Vorhaben sprechen. Wir entwickeln gemeinsam die optimale Lösung für Ihre Baustelle.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a 
                href="/kontakt"
                class="inline-flex items-center justify-center px-8 py-4 bg-background text-white font-bold text-base rounded hover:bg-background/90 transition-colors focus:outline-none focus-visible:ring-4 focus-visible:ring-background/50"
                aria-label="Jetzt Kontakt aufnehmen"
              >
                Kostenloses Gespräch vereinbaren
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Hinweis Section -->
    <section class="py-8 md:py-12 bg-black/20" aria-label="Rechtlicher Hinweis">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-start gap-4 p-6 bg-accent/5 border border-accent/20 rounded-xl">
          <svg class="w-6 h-6 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div>
            <h3 class="text-white font-semibold mb-1">Wichtiger Hinweis</h3>
            <p class="text-secondary text-sm">
              Sicherheitsleistungen erfolgen im Rahmen der gesetzlichen Bestimmungen und in Zusammenarbeit mit entsprechend zugelassenen Partnern.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <WhatsAppButton />
</Layout>
